{
  "name": "agentlend",
  "version": "1.0.0",
  "description": "AgentLend - Algorithmic A2A Credit Protocol for CROO Network",
  "private": true,
  "workspaces": [
    "contracts",
    "ml-oracle",
    "dashboard"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "dev:oracle": "npm run dev --workspace=ml-oracle",
    "dev:dashboard": "npm run dev --workspace=dashboard",
    "contracts:compile": "npm run compile --workspace=contracts",
    "contracts:test": "npm run test --workspace=contracts",
    "contracts:deploy": "npm run deploy --workspace=contracts"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}