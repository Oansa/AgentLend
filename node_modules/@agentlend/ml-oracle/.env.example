# ML Oracle Service Configuration
# Copy to .env and fill in values

# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Logging
LOG_LEVEL=info
LOG_PRETTY=true

# Redis (for BullMQ job queue)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Ethereum/CROO Network
CHAIN_ID=84532
RPC_URL=https://sepolia.base.org
PRIVATE_KEY=
ORACLE_SIGNER_ADDRESS=

# Contract Addresses (Base Sepolia)
ACS_ORACLE_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
COLLATERAL_MANAGER_ADDRESS=0xe7f1725E7734CE288F8367e1Bb143E90bb3F0512
LENDING_POOL_ADDRESS=0x9fE46736679d2D9a65F0992F2272dE9f3c7fa6e0
USDC_ADDRESS=0xa513E6E4b8f2a923D98304ec87F64353C4D5C853

# ACS Scoring Configuration
SCORE_VALIDITY_SECONDS=600
MIN_SCORE=300
MAX_SCORE=900

# External APIs for credit scoring
COINGECKO_API_KEY=
ALCHEMY_API_KEY=
MORALIS_API_KEY=

# CROO CAP Integration
CAP_API_URL=https://api.croo.network
CAP_WS_URL=wss://ws.croo.network
CAP_API_KEY=croo_sk_29a541a09bfa070ec2b0daf14c6256a7
CROO_AGENT_DID=did:croo:agentlend
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://ws.croo.network

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Metrics
METRICS_ENABLED=true
METRICS_PORT=9090