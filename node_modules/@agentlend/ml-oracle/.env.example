# ML Oracle Service Configuration
# Copy to .env and fill in values

# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Logging
LOG_LEVEL=info
LOG_PRETTY=true

# Redis (for BullMQ job queue)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Ethereum/CROO Network
CHAIN_ID=84532
RPC_URL=https://sepolia.base.org
PRIVATE_KEY=
ORACLE_SIGNER_ADDRESS=

# Contract Addresses (Base Sepolia)
ACS_ORACLE_ADDRESS=
COLLATERAL_MANAGER_ADDRESS=
LENDING_POOL_ADDRESS=
USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# ACS Scoring Configuration
SCORE_VALIDITY_SECONDS=600
MIN_SCORE=300
MAX_SCORE=900

# External APIs for credit scoring
COINGECKO_API_KEY=
ALCHEMY_API_KEY=
MORALIS_API_KEY=

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Metrics
METRICS_ENABLED=true
METRICS_PORT=9090